# Oversized processed videos — exceed Cloudflare Pages 25 MB file limit
public/projects/dataviz/videos/data-viz-cop-main.webm

# Raw splat PLYs (~94 MB each) — exceed Cloudflare's 25 MB limit; prod uses the SOGs.
# Kept locally only for the dev /splat .ply↔.sog A/B toggle.
public/projects/sun-matters/splat/*.ply

# Unreferenced H264 source copy
